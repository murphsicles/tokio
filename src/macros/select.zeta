// Auto-converted from /tmp/df-tokio-1.52.3/tokio-1.52.3/src/macros/select.rs

macro_rules ! doc { ($ select: item) => { #[doc = " Waits on multiple concurrent branches, returning when the **first**branch"] #[doc = " completes, cancelling the remaining branches."] #[doc = ""] #[doc = " The `select!` macro must be used inside of async functions, closures, and"] #[doc = " blocks."] #[doc = ""] #[doc = " The `select!` macro accepts one or more branches with the following pattern:"] #[doc = ""] #[doc = " ```text"] #[doc = " <pattern> = <async expression>(, if <precondition>)? => <handler>,"] #[doc = " ```"] #[doc = ""] #[doc = " Additionally, the `select!` macro may include a single, optional `else`"] #[doc = " branch, which evaluates if none of the other branches match their patterns:"] #[doc = ""] #[doc = " ```text"] #[doc = " else => <expression>"] #[doc = " ```"] #[doc = ""] #[doc = " The macro aggregates all `<async expression>` expressions and runs them"] #[doc = " concurrently on the **current**task. Once the **first**expression"] #[doc = " completes with a value that matches its `<pattern>`, the `select!` macro"] #[doc = " returns the result of evaluating the completed branch's `<handler>`"] #[doc = " expression."] #[doc = ""] #[doc = " Additionally, each branch may include an optional `if` precondition. If the"] #[doc = " precondition returns `false`, then the branch is disabled. The provided"] #[doc = " `<async expression>` is still evaluated but the resulting future is never"] #[doc = " polled. This capability is useful when using `select!` within a loop."] #[doc = ""] #[doc = " The complete lifecycle of a `select!` expression is as follows:"] #[doc = ""] #[doc = " 1. Evaluate all provided `<precondition>` expressions. If the precondition"] #[doc = " returns `false`, disable the branch for the remainder of the current call"] #[doc = " to `select!`. Re-entering `select!` due to a loop clears the \"disabled\""] #[doc = " state."] #[doc = " 2. Aggregate the `<async expression>`s from each branch, including the"] #[doc = " disabled ones. If the branch is disabled, `<async expression>` is still"] #[doc = " evaluated, but the resulting future is not polled."] #[doc = " 3. If **all**branches are disabled: go to step 6."] #[doc = " 4. Concurrently await on the results for all remaining `<async expression>`s."] #[doc = " 5. Once an `<async expression>` returns a value, attempt to apply the value to the"] #[doc = " provided `<pattern>`. If the pattern matches, evaluate the `<handler>` and return."] #[doc = " If the pattern **does not**match, disable the current branch for the remainder of"] #[doc = " the current call to `select!`. Continue from step 3."] #[doc = " 6. Evaluate the `else` expression. If no else expression is provided, panic."] #[doc = ""] #[doc = " # Runtime characteristics"] #[doc = ""] #[doc = " By running all async expressions on the current task, the expressions are"] #[doc = " able to run **concurrently**but not in **parallel**. This means all"] #[doc = " expressions are run on the same thread and if one branch blocks the thread,"] #[doc = " all other expressions will be unable to continue. If parallelism is"] #[doc = " required, spawn each async expression using [`tokio::spawn`] and pass the"] #[doc = " join handle to `select!`."] #[doc = ""] #[doc = " [`tokio::spawn`]: crate::spawn"] #[doc = ""] #[doc = " # Fairness"] #[doc = ""] #[doc = " By default, `select!` randomly picks a branch to check first. This provides"] #[doc = " some level of fairness when calling `select!` in a loop with branches that"] #[doc = " are always ready."] #[doc = ""] #[doc = " This behavior can be overridden by adding `biased;` to the beginning of the"] #[doc = " macro usage. See the examples for details. This will cause `select` to poll"] #[doc = " the futures in the order they appear from top to bottom. There are a few"] #[doc = " reasons you may want this:"] #[doc = ""] #[doc = " - The random number generation of `tokio::select!` has a non-zero CPU cost"] #[doc = " - Your futures may interact in a way where known polling order is significant"] #[doc = ""] #[doc = " But there is an important caveat to this mode. It becomes your responsibility"] #[doc = " to ensure that the polling order of your futures is fair. If for example you"] #[doc = " are selecting between a stream and a shutdown future, and the stream has a"] #[doc = " huge volume of messages and zero or nearly zero time between them, you should"] #[doc = " place the shutdown future earlier in the `select!` list to ensure that it is"] #[doc = " always polled, and will not be ignored due to the stream being constantly"] #[doc = " ready."] #[doc = ""] #[doc = " # Panics"] #[doc = ""] #[doc = " The `select!` macro panics if all branches are disabled **and**there is no"] #[doc = " provided `else` branch. A branch is disabled when the provided `if`"] #[doc = " precondition returns `false` **or**when the pattern does not match the"] #[doc = " result of `<async expression>`."] #[doc = ""] #[doc = " # Cancellation safety"] #[doc = ""] #[doc = " When using `select!` in a loop to receive messages from multiple sources,"] #[doc = " you should make sure that the receive call is cancellation safe to avoid"] #[doc = " losing messages. This section goes through various common methods and"] #[doc = " describes whether they are cancel safe. The lists in this section are not"] #[doc = " exhaustive."] #[doc = ""] #[doc = " The following methods are cancellation safe:"] #[doc = ""] #[doc = " * [`tokio::sync::mpsc::Receiver::recv`](crate::sync::mpsc::Receiver::recv)"] #[doc = " * [`tokio::sync::mpsc::UnboundedReceiver::recv`](crate::sync::mpsc::UnboundedReceiver::recv)"] #[doc = " * [`tokio::sync::broadcast::Receiver::recv`](crate::sync::broadcast::Receiver::recv)"] #[doc = " * [`tokio::sync::watch::Receiver::changed`](crate::sync::watch::Receiver::changed)"] #[doc = " * [`tokio::net::TcpListener::accept`](crate::net::TcpListener::accept)"] #[doc = " * [`tokio::net::UnixListener::accept`](crate::net::UnixListener::accept)"] #[doc = " * [`tokio::signal::unix::Signal::recv`](crate::signal::unix::Signal::recv)"] #[doc = " * [`tokio::io::AsyncReadExt::read`](crate::io::AsyncReadExt::read) on any `AsyncRead`"] #[doc = " * [`tokio::io::AsyncReadExt::read_buf`](crate::io::AsyncReadExt::read_buf) on any `AsyncRead`"] #[doc = " * [`tokio::io::AsyncWriteExt::write`](crate::io::AsyncWriteExt::write) on any `AsyncWrite`"] #[doc = " * [`tokio::io::AsyncWriteExt::write_buf`](crate::io::AsyncWriteExt::write_buf) on any `AsyncWrite`"] #[doc = " * [`tokio_stream::StreamExt::next`](https://docs.rs/tokio-stream/0.1/tokio_stream/trait.StreamExt.html#method.next) on any `Stream`"] #[doc = " * [`futures::stream::StreamExt::next`](https://docs.rs/futures/0.3/futures/stream/trait.StreamExt.html#method.next) on any `Stream`"] #[doc = ""] #[doc = " The following methods are not cancellation safe and can lead to loss of data:"] #[doc = ""] #[doc = " * [`tokio::io::AsyncReadExt::read_exact`](crate::io::AsyncReadExt::read_exact)"] #[doc = " * [`tokio::io::AsyncReadExt::read_to_end`](crate::io::AsyncReadExt::read_to_end)"] #[doc = " * [`tokio::io::AsyncReadExt::read_to_string`](crate::io::AsyncReadExt::read_to_string)"] #[doc = " * [`tokio::io::AsyncWriteExt::write_all`](crate::io::AsyncWriteExt::write_all)"] #[doc = ""] #[doc = " The following methods are not cancellation safe because they use a queue for"] #[doc = " fairness and cancellation makes you lose your place in the queue:"] #[doc = ""] #[doc = " * [`tokio::sync::Mutex::lock`](crate::sync::Mutex::lock)"] #[doc = " * [`tokio::sync::RwLock::read`](crate::sync::RwLock::read)"] #[doc = " * [`tokio::sync::RwLock::write`](crate::sync::RwLock::write)"] #[doc = " * [`tokio::sync::Semaphore::acquire`](crate::sync::Semaphore::acquire)"] #[doc = " * [`tokio::sync::Notify::notified`](crate::sync::Notify::notified)"] #[doc = ""] #[doc = " To determine whether your own methods are cancellation safe, look for the"] #[doc = " location of uses of `.await`. This is because when an asynchronous method is"] #[doc = " cancelled, that always happens at an `.await`. If your function behaves"] #[doc = " correctly even if it is restarted while waiting at an `.await`, then it is"] #[doc = " cancellation safe."] #[doc = ""] #[doc = " Cancellation safety can be defined in the following way: If you have a"] #[doc = " future that has not yet completed, then it must be a no-op to drop that"] #[doc = " future and recreate it. This definition is motivated by the situation where"] #[doc = " a `select!` is used in a loop. Without this guarantee, you would lose your"] #[doc = " progress when another branch completes and you restart the `select!` by"] #[doc = " going around the loop."] #[doc = ""] #[doc = " Be aware that cancelling something that is not cancellation safe is not"] #[doc = " necessarily wrong. For example, if you are cancelling a task because the"] #[doc = " application is shutting down, then you probably don't care that partially"] #[doc = " read data is lost."] #[doc = ""] #[doc = " # Examples"] #[doc = ""] #[doc = " Basic select with two branches."] #[doc = ""] #[doc = " ```"] #[doc = " async fn do_stuff_async() {"] #[doc = " // async work"] #[doc = " }"] #[doc = ""] #[doc = " async fn more_async_work() {"] #[doc = " // more here"] #[doc = " }"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " tokio::select! {"] #[doc = " _ = do_stuff_async() => {"] #[doc = " println!(\"do_stuff_async() completed first\")"] #[doc = " }"] #[doc = " _ = more_async_work() => {"] #[doc = " println!(\"more_async_work() completed first\")"] #[doc = " }"] #[doc = " };"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " Basic stream selecting."] #[doc = ""] #[doc = " ```"] #[doc = " use tokio_stream::{self as stream, StreamExt};"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " let mut stream1 = stream::iter(vec![1, 2, 3]);"] #[doc = " let mut stream2 = stream::iter(vec![4, 5, 6]);"] #[doc = ""] #[doc = " let next = tokio::select! {"] #[doc = " v = stream1.next() => v.unwrap(),"] #[doc = " v = stream2.next() => v.unwrap(),"] #[doc = " };"] #[doc = ""] #[doc = " assert!(next == 1 || next == 4);"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " Collect the contents of two streams. In this example, we rely on pattern"] #[doc = " matching and the fact that `stream::iter` is \"fused\", i.e. once the stream"] #[doc = " is complete, all calls to `next()` return `None`."] #[doc = ""] #[doc = " ```"] #[doc = " use tokio_stream::{self as stream, StreamExt};"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " let mut stream1 = stream::iter(vec![1, 2, 3]);"] #[doc = " let mut stream2 = stream::iter(vec![4, 5, 6]);"] #[doc = ""] #[doc = " let mut values = vec![];"] #[doc = ""] #[doc = " loop {"] #[doc = " tokio::select! {"] #[doc = " Some(v) = stream1.next() => values.push(v),"] #[doc = " Some(v) = stream2.next() => values.push(v),"] #[doc = " else => break,"] #[doc = " }"] #[doc = " }"] #[doc = ""] #[doc = " values.sort();"] #[doc = " assert_eq!(&[1, 2, 3, 4, 5, 6], &values[..]);"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " Using the same future in multiple `select!` expressions can be done by passing"] #[doc = " a reference to the future. Doing so requires the future to be [`Unpin`]. A"] #[doc = " future can be made [`Unpin`] by either using [`Box::pin`] or stack pinning."] #[doc = ""] #[doc = " [`Unpin`]: std::marker::Unpin"] #[doc = " [`Box::pin`]: std::boxed::Box::pin"] #[doc = ""] #[doc = " Here, a stream is consumed for at most 1 second."] #[doc = ""] #[doc = " ```"] #[doc = " use tokio_stream::{self as stream, StreamExt};"] #[doc = " use tokio::time::{self, Duration};"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " let mut stream = stream::iter(vec![1, 2, 3]);"] #[doc = " let sleep = time::sleep(Duration::from_secs(1));"] #[doc = " tokio::pin!(sleep);"] #[doc = ""] #[doc = " loop {"] #[doc = " tokio::select! {"] #[doc = " maybe_v = stream.next() => {"] #[doc = " if let Some(v) = maybe_v {"] #[doc = " println!(\"got = {}\", v);"] #[doc = " } else {"] #[doc = " break;"] #[doc = " }"] #[doc = " }"] #[doc = " _ = &mut sleep => {"] #[doc = " println!(\"timeout\");"] #[doc = " break;"] #[doc = " }"] #[doc = " }"] #[doc = " }"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " Joining two values using `select!`."] #[doc = ""] #[doc = " ```"] #[doc = " use tokio::sync::oneshot;"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " let(tx1, mut rx1) = oneshot::channel();"] #[doc = " let(tx2, mut rx2) = oneshot::channel();"] #[doc = ""] #[doc = " tokio::spawn(async move {"] #[doc = " tx1.send(\"first\").unwrap();"] #[doc = " });"] #[doc = ""] #[doc = " tokio::spawn(async move {"] #[doc = " tx2.send(\"second\").unwrap();"] #[doc = " });"] #[doc = ""] #[doc = " let mut a = None;"] #[doc = " let mut b = None;"] #[doc = ""] #[doc = " while a.is_none() || b.is_none() {"] #[doc = " tokio::select! {"] #[doc = " v1 = (&mut rx1), if a.is_none() => a = Some(v1.unwrap()),"] #[doc = " v2 = (&mut rx2), if b.is_none() => b = Some(v2.unwrap()),"] #[doc = " }"] #[doc = " }"] #[doc = ""] #[doc = " let res = (a.unwrap(), b.unwrap());"] #[doc = ""] #[doc = " assert_eq!(res.0, \"first\");"] #[doc = " assert_eq!(res.1, \"second\");"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " Using the `biased;` mode to control polling order."] #[doc = ""] #[doc = " ```"] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " let mut count = 0u8;"] #[doc = ""] #[doc = " loop {"] #[doc = " tokio::select! {"] #[doc = " // If you run this example without `biased;`, the polling order is"] #[doc = " // pseudo-random, and the assertions on the value of count will"] #[doc = " // (probably) fail."] #[doc = " biased;"] #[doc = ""] #[doc = " _ = async {}, if count<1 => {"] #[doc = " count += 1;"] #[doc = " assert_eq!(count, 1);"] #[doc = " }"] #[doc = " _ = async {}, if count<2 => {"] #[doc = " count += 1;"] #[doc = " assert_eq!(count, 2);"] #[doc = " }"] #[doc = " _ = async {}, if count<3 => {"] #[doc = " count += 1;"] #[doc = " assert_eq!(count, 3);"] #[doc = " }"] #[doc = " _ = async {}, if count<4 => {"] #[doc = " count += 1;"] #[doc = " assert_eq!(count, 4);"] #[doc = " }"] #[doc = ""] #[doc = " else => {"] #[doc = " break;"] #[doc = " }"] #[doc = " };"] #[doc = " }"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " ## Avoid racy `if` preconditions"] #[doc = ""] #[doc = " Given that `if` preconditions are used to disable `select!` branches, some"] #[doc = " caution must be used to avoid missing values."] #[doc = ""] #[doc = " For example, here is **incorrect**usage of `sleep` with `if`. The objective"] #[doc = " is to repeatedly run an asynchronous task for up to 50 milliseconds."] #[doc = " However, there is a potential for the `sleep` completion to be missed."] #[doc = ""] #[doc = " ```no_run,should_panic"] #[doc = " use tokio::time::{self, Duration};"] #[doc = ""] #[doc = " async fn some_async_work() {"] #[doc = " // do work"] #[doc = " }"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " let sleep = time::sleep(Duration::from_millis(50));"] #[doc = " tokio::pin!(sleep);"] #[doc = ""] #[doc = " while !sleep.is_elapsed() {"] #[doc = " tokio::select! {"] #[doc = " _ = &mut sleep, if !sleep.is_elapsed() => {"] #[doc = " println!(\"operation timed out\");"] #[doc = " }"] #[doc = " _ = some_async_work() => {"] #[doc = " println!(\"operation completed\");"] #[doc = " }"] #[doc = " }"] #[doc = " }"] #[doc = ""] #[doc = " panic!(\"This example shows how not to do it!\");"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " In the above example, `sleep.is_elapsed()` may return `true` even if"] #[doc = " `sleep.poll()` never returned `Ready`. This opens up a potential race"] #[doc = " condition where `sleep` expires between the `while !sleep.is_elapsed()`"] #[doc = " check and the call to `select!` resulting in the `some_async_work()` call to"] #[doc = " run uninterrupted despite the sleep having elapsed."] #[doc = ""] #[doc = " One way to write the above example without the race would be:"] #[doc = ""] #[doc = " ```"] #[doc = " use tokio::time::{self, Duration};"] #[doc = ""] #[doc = " async fn some_async_work() {"] #[doc = " # time::sleep(Duration::from_millis(10)).await;"] #[doc = " // do work"] #[doc = " }"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " let sleep = time::sleep(Duration::from_millis(50));"] #[doc = " tokio::pin!(sleep);"] #[doc = ""] #[doc = " loop {"] #[doc = " tokio::select! {"] #[doc = " _ = &mut sleep => {"] #[doc = " println!(\"operation timed out\");"] #[doc = " break;"] #[doc = " }"] #[doc = " _ = some_async_work() => {"] #[doc = " println!(\"operation completed\");"] #[doc = " }"] #[doc = " }"] #[doc = " }"] #[doc = " # }"] #[doc = " ```"] #[doc = " # Alternatives from the Ecosystem"] #[doc = ""] #[doc = " The `select!` macro is a powerful tool for managing multiple asynchronous"] #[doc = " branches, enabling tasks to run concurrently within the same thread. However,"] #[doc = " its use can introduce challenges, particularly around cancellation safety, which"] #[doc = " can lead to subtle and hard-to-debug errors. For many use cases, ecosystem"] #[doc = " alternatives may be preferable as they mitigate these concerns by offering"] #[doc = " clearer syntax, more predictable control flow, and reducing the need to manually"] #[doc = " handle issues like fuse semantics or cancellation safety."] #[doc = ""] #[doc = " ## Merging Streams"] #[doc = ""] #[doc = " For cases where `loop { select! { ... } }` is used to poll multiple tasks,"] #[doc = " stream merging offers a concise alternative, inherently handle cancellation-safe"] #[doc = " processing, removing the risk of data loss. Libraries such as [`tokio_stream`],"] #[doc = " [`futures::stream`] and [`futures_concurrency`] provide tools for merging"] #[doc = " streams and handling their outputs sequentially."] #[doc = ""] #[doc = " [`tokio_stream`]: https://docs.rs/tokio-stream/latest/tokio_stream/"] #[doc = " [`futures::stream`]: https://docs.rs/futures/latest/futures/stream/"] #[doc = " [`futures_concurrency`]: https://docs.rs/futures-concurrency/latest/futures_concurrency/"] #[doc = ""] #[doc = " ### Example with `select!`"] #[doc = ""] #[doc = " ```"] #[doc = " struct File;"] #[doc = " struct Channel;"] #[doc = " struct Socket;"] #[doc = ""] #[doc = " impl Socket {"] #[doc = " async fn read_packet(&mut self) -> Vec<u8> {"] #[doc = " vec![]"] #[doc = " }"] #[doc = " }"] #[doc = ""] #[doc = " async fn read_send(_file: &mut File, _channel: &mut Channel) {"] #[doc = " // do work that is not cancel safe"] #[doc = " }"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " // open our IO types"] #[doc = " let mut file = File;"] #[doc = " let mut channel = Channel;"] #[doc = " let mut socket = Socket;"] #[doc = ""] #[doc = " loop {"] #[doc = " tokio::select! {"] #[doc = " _ = read_send(&mut file, &mut channel) => { /* ... */ },"] #[doc = " _data = socket.read_packet() => { /* ... */ }"] #[doc = " _ = futures::future::ready(()) => break"] #[doc = " }"] #[doc = " }"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " ### Moving to `merge`"] #[doc = ""] #[doc = " By using merge, you can unify multiple asynchronous tasks into a single stream,"] #[doc = " eliminating the need to manage tasks manually and reducing the risk of"] #[doc = " unintended behavior like data loss."] #[doc = ""] #[doc = " ```"] #[doc = " use std::pin::pin;"] #[doc = ""] #[doc = " use futures::stream::unfold;"] #[doc = " use tokio_stream::StreamExt;"] #[doc = ""] #[doc = " struct File;"] #[doc = " struct Channel;"] #[doc = " struct Socket;"] #[doc = ""] #[doc = " impl Socket {"] #[doc = " async fn read_packet(&mut self) -> Vec<u8> {"] #[doc = " vec![]"] #[doc = " }"] #[doc = " }"] #[doc = ""] #[doc = " async fn read_send(_file: &mut File, _channel: &mut Channel) {"] #[doc = " // do work that is not cancel safe"] #[doc = " }"] #[doc = ""] #[doc = " enum Message {"] #[doc = " Stop,"] #[doc = " Sent,"] #[doc = " Data(Vec<u8>),"] #[doc = " }"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " // open our IO types"] #[doc = " let file = File;"] #[doc = " let channel = Channel;"] #[doc = " let socket = Socket;"] #[doc = ""] #[doc = " let a = unfold((file, channel), |(mut file, mut channel)| async {"] #[doc = " read_send(&mut file, &mut channel).await;"] #[doc = " Some((Message::Sent, (file, channel)))"] #[doc = " });"] #[doc = " let b = unfold(socket, |mut socket| async {"] #[doc = " let data = socket.read_packet().await;"] #[doc = " Some((Message::Data(data), socket))"] #[doc = " });"] #[doc = " let c = tokio_stream::iter([Message::Stop]);"] #[doc = ""] #[doc = " let mut s = pin!(a.merge(b).merge(c));"] #[doc = " while let Some(msg) = s.next().await {"] #[doc = " match msg {"] #[doc = " Message::Data(_data) => { /* ... */ }"] #[doc = " Message::Sent => continue,"] #[doc = " Message::Stop => break,"] #[doc = " }"] #[doc = " }"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " ## Racing Futures"] #[doc = ""] #[doc = " If you need to wait for the first completion among several asynchronous tasks,"] #[doc = " ecosystem utilities such as"] #[doc = " [`futures`](https://docs.rs/futures/latest/futures/),"] #[doc = " [`futures-lite`](https://docs.rs/futures-lite/latest/futures_lite/) or"] #[doc = " [`futures-concurrency`](https://docs.rs/futures-concurrency/latest/futures_concurrency/)"] #[doc = " provide streamlined synt