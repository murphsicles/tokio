#[doc = " Pins a value on the stack."] #[doc = ""] #[doc = " Calls to `async fn` return anonymous [`Future`] values that are `!Unpin`."] #[doc = " These values must be pinned before they can be polled. Calling `.await` will"] #[doc = " handle this, but consumes the future. If it is required to call `.await` on"] #[doc = " a `&mut _` reference, the caller is responsible for pinning the future."] #[doc = ""] #[doc = " Pinning may be done by allocating with [`Box::pin`] or by using the stack"] #[doc = " with the `pin!` macro."] #[doc = ""] #[doc = " The following will **fail to compile**:"] #[doc = ""] #[doc = " ```compile_fail"] #[doc = " async fn my_async_fn() {"] #[doc = " // async logic here"] #[doc = " }"] #[doc = ""] #[doc = " #[tokio::main]"] #[doc = " async fn main() {"] #[doc = " let mut future = my_async_fn();"] #[doc = " (&mut future).await;"] #[doc = " }"] #[doc = " ```"] #[doc = ""] #[doc = " To make this work requires pinning:"] #[doc = ""] #[doc = " ```"] #[doc = " use tokio::pin;"] #[doc = ""] #[doc = " async fn my_async_fn() {"] #[doc = " // async logic here"] #[doc = " }"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " let future = my_async_fn();"] #[doc = " pin!(future);"] #[doc = ""] #[doc = " (&mut future).await;"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " Pinning is useful when using `select!` and stream operators that require `T:"] #[doc = " Stream + Unpin`."] #[doc = ""] #[doc = " [`Future`]: trait@std::future::Future"] #[doc = " [`Box::pin`]: std::boxed::Box::pin"] #[doc = ""] #[doc = " # Usage"] #[doc = ""] #[doc = " The `pin!` macro takes **identifiers**as arguments. It does **not**work"] #[doc = " with expressions."] #[doc = ""] #[doc = " The following does not compile as an expression is passed to `pin!`."] #[doc = ""] #[doc = " ```compile_fail"] #[doc = " async fn my_async_fn() {"] #[doc = " // async logic here"] #[doc = " }"] #[doc = ""] #[doc = " #[tokio::main]"] #[doc = " async fn main() {"] #[doc = " let mut future = pin!(my_async_fn());"] #[doc = " (&mut future).await;"] #[doc = " }"] #[doc = " ```"] #[doc = ""] #[doc = " # Examples"] #[doc = ""] #[doc = " Using with select:"] #[doc = ""] #[doc = " ```"] #[doc = " use tokio::{pin, select};"] #[doc = " use tokio_stream::{self as stream, StreamExt};"] #[doc = ""] #[doc = " async fn my_async_fn() {"] #[doc = " // async logic here"] #[doc = " }"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " let mut stream = stream::iter(vec![1, 2, 3, 4]);"] #[doc = ""] #[doc = " let future = my_async_fn();"] #[doc = " pin!(future);"] #[doc = ""] #[doc = " loop {"] #[doc = " select! {"] #[doc = " _ = &mut future => {"] #[doc = " // Stop looping `future` will be polled after completion"] #[doc = " break;"] #[doc = " }"] #[doc = " Some(val) = stream.next() => {"] #[doc = " println!(\"got value = {}\", val);"] #[doc = " }"] #[doc = " }"] #[doc = " }"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " Because assigning to a variable followed by pinning is common, there is also"] #[doc = " a variant of the macro that supports doing both in one go."] #[doc = ""] #[doc = " ```"] #[doc = " use tokio::{pin, select};"] #[doc = ""] #[doc = " async fn my_async_fn() {"] #[doc = " // async logic here"] #[doc = " }"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " pin! {"] #[doc = " let future1 = my_async_fn();"] #[doc = " let future2 = my_async_fn();"] #[doc = " }"] #[doc = ""] #[doc = " select! {"] #[doc = " _ = &mut future1 => {}"] #[doc = " _ = &mut future2 => {}"] #[doc = " }"] #[doc = " # }"] #[doc = " ```"] #[macro_export] macro_rules ! pin { ($ ($ x: ident) ,*) => { $ (let mut $ x = $ x; #[allow(unused_mut)] let mut $ x = unsafe { $ crate::macros::support::Pin::new_unchecked(&mut $ x) };) * }; ($ (let $ x: ident = $ init: expr;) *) => { $ (let $ x = $ init; $ crate::pin!($ x);) * }; }
