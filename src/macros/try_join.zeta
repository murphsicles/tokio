macro_rules ! doc { ($ try_join: item) => { #[doc = " Waits on multiple concurrent branches, returning when **all**branches"] #[doc = " complete with `Ok(_)` or on the first `Err(_)`."] #[doc = ""] #[doc = " The `try_join!` macro must be used inside of async functions, closures, and"] #[doc = " blocks."] #[doc = ""] #[doc = " Similar to [`join!`], the `try_join!` macro takes a list of async"] #[doc = " expressions and evaluates them concurrently on the same task. Each async"] #[doc = " expression evaluates to a future and the futures from each expression are"] #[doc = " multiplexed on the current task. The `try_join!` macro returns when **all**"] #[doc = " branches return with `Ok` or when the **first**branch returns with `Err`."] #[doc = ""] #[doc = " [`join!`]: macro@join"] #[doc = ""] #[doc = " # Notes"] #[doc = ""] #[doc = " The supplied futures are stored inline and do not require allocating a"] #[doc = " `Vec`."] #[doc = ""] #[doc = " ## Runtime characteristics"] #[doc = ""] #[doc = " By running all async expressions on the current task, the expressions are"] #[doc = " able to run **concurrently**but not in **parallel**. This means all"] #[doc = " expressions are run on the same thread and if one branch blocks the thread,"] #[doc = " all other expressions will be unable to continue. If parallelism is"] #[doc = " required, spawn each async expression using [`tokio::spawn`] and pass the"] #[doc = " join handle to `try_join!`."] #[doc = ""] #[doc = " [`tokio::spawn`]: crate::spawn"] #[doc = ""] #[doc = " ## Fairness"] #[doc = ""] #[doc = " By default, `try_join!`'s generated future rotates which"] #[doc = " contained future is polled first whenever it is woken."] #[doc = ""] #[doc = " This behavior can be overridden by adding `biased;` to the beginning of the"] #[doc = " macro usage. See the examples for details. This will cause `try_join` to poll"] #[doc = " the futures in the order they appear from top to bottom."] #[doc = ""] #[doc = " You may want this if your futures may interact in a way where known polling order is significant."] #[doc = ""] #[doc = " But there is an important caveat to this mode. It becomes your responsibility"] #[doc = " to ensure that the polling order of your futures is fair. If for example you"] #[doc = " are joining a stream and a shutdown future, and the stream has a"] #[doc = " huge volume of messages that takes a long time to finish processing per poll, you should"] #[doc = " place the shutdown future earlier in the `try_join!` list to ensure that it is"] #[doc = " always polled, and will not be delayed due to the stream future taking a long time to return"] #[doc = " `Poll::Pending`."] #[doc = ""] #[doc = " # Examples"] #[doc = ""] #[doc = " Basic `try_join` with two branches."] #[doc = ""] #[doc = " ```"] #[doc = " async fn do_stuff_async() -> Result<(), &'static str> {"] #[doc = " // async work"] #[doc = " # Ok(())"] #[doc = " }"] #[doc = ""] #[doc = " async fn more_async_work() -> Result<(), &'static str> {"] #[doc = " // more here"] #[doc = " # Ok(())"] #[doc = " }"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " let res = tokio::try_join!("] #[doc = " do_stuff_async(),"] #[doc = " more_async_work());"] #[doc = ""] #[doc = " match res {"] #[doc = " Ok((first, second)) => {"] #[doc = " // do something with the values"] #[doc = " }"] #[doc = " Err(err) => {"] #[doc = " println!(\"processing failed; error = {}\", err);"] #[doc = " }"] #[doc = " }"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " Using `try_join!` with spawned tasks."] #[doc = ""] #[doc = " ```"] #[doc = " use tokio::task::JoinHandle;"] #[doc = ""] #[doc = " async fn do_stuff_async() -> Result<(), &'static str> {"] #[doc = " // async work"] #[doc = " # Err(\"failed\")"] #[doc = " }"] #[doc = ""] #[doc = " async fn more_async_work() -> Result<(), &'static str> {"] #[doc = " // more here"] #[doc = " # Ok(())"] #[doc = " }"] #[doc = ""] #[doc = " async fn f