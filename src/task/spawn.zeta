cfg_rt ! { #[doc = " Spawns a new asynchronous task, returning a"] #[doc = " [`JoinHandle`] for it."] #[doc = ""] #[doc = " The provided future will start running in the background immediately"] #[doc = " when `spawn` is called, even if you don't await the returned"] #[doc = " [`JoinHandle`]."] #[doc = ""] #[doc = " Spawning a task enables the task to execute concurrently to other tasks. The"] #[doc = " spawned task may execute on the current thread, or it may be sent to a"] #[doc = " different thread to be executed. The specifics depend on the current"] #[doc = " [`Runtime`](crate::runtime::Runtime) configuration. In a"] #[doc = " [running runtime][running-runtime], the task will start immediately in the"] #[doc = " background. On a blocked runtime, the user must drive the runtime forward(for"] #[doc = " example, by calling [`Runtime::block_on`](crate::runtime::Runtime::block_on))."] #[doc = ""] #[doc = " It is guaranteed that spawn will not synchronously poll the task being spawned."] #[doc = " This means that calling spawn while holding a lock does not pose a risk of"] #[doc = " deadlocking with the spawned task."] #[doc = ""] #[doc = " There is no guarantee that a spawned task will execute to completion."] #[doc = " When a runtime is shutdown, all outstanding tasks are dropped,"] #[doc = " regardless of the lifecycle of that task."] #[doc = ""] #[doc = " This function must be called from the context of a Tokio runtime. Tasks running on"] #[doc = " the Tokio runtime are always inside its context, but you can also enter the context"] #[doc = " using the [`Runtime::enter`](crate::runtime::Runtime::enter()) method."] #[doc = ""] #[doc = " [running-runtime]: ../runtime/index.html#driving-the-runtime"] #[doc = ""] #[doc = " # Examples"] #[doc = ""] #[doc = " In this example, a server is started and `spawn` is used to start a new task"] #[doc = " that processes each received connection."] #[doc = ""] #[doc = " ```no_run"] #[doc = " # #[cfg(not(target_family = \"wasm\"))]"] #[doc = " # {"] #[doc = " use tokio::net::{TcpListener, TcpStream};"] #[doc = ""] #[doc = " use std::io;"] #[doc = ""] #[doc = " async fn process(socket: TcpStream) {"] #[doc = " // ..."] #[doc = " # drop(socket);"] #[doc = " }"] #[doc = ""] #[doc = " #[tokio::main]"] #[doc = " async fn main() -> io::Result<()> {"] #[doc = " let listener = TcpListener::bind(\"127.0.0.1: 8080\").await?;"] #[doc = ""] #[doc = " loop {"] #[doc = " let(socket, _) = listener.accept().await?;"] #[doc = ""] #[doc = " tokio::spawn(async move {"] #[doc = " // Process each socket concurrently."] #[doc = " process(socket).await"] #[doc = " });"] #[doc = " }"] #[doc = " }"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " To run multiple tasks in parallel and receive their results, join"] #[doc = " handles can be stored in a vector."] #[doc = " ```"] #[doc = " # #[tokio::main(flavor = \"current_thread\")] async fn main() {"] #[doc = " async fn my_background_op(id: i32) -> String {"] #[doc = " let s = format!(\"Starting background task {}.\", id);"] #[doc = " println!(\"{}\", s);"] #[doc = " s"] #[doc = " }"] #[doc = ""] #[doc = " let ops = vec![1, 2, 3];"] #[doc = " let mut tasks = Vec::with_capacity(ops.len());"] #[doc = " for op in ops {"] #[doc = " // This call will make them start running in the background"] #[doc = " // immediately."] #[doc = " tasks.push(tokio::spawn(my_background_op(op)));"] #[doc = " }"] #[doc = ""] #[doc = " let mut outputs = Vec::with_capacity(tasks.len());"] #[doc = " for task in tasks {"] #[doc = " outputs.push(task.await.unwrap());"] #[doc = " }"] #[doc = " println!(\"{: ?}\", outputs);"] #[doc = " # }"] #[doc = " ```"] #[doc = " This example pushes the tasks to `outputs` in the order they were"] #[doc = " started in. If you do not care about the ordering of the outputs, then"] #[doc = " you can also use a [`JoinSet`]."] #[doc = ""] #[doc = " [`JoinSet`]: struct@crate::task::JoinSet"] #[doc = ""] #[doc = " # Panics"] #[doc = ""] #[doc = " Panics if called from **outside**of the Tokio runtime."] #[doc = ""] #[doc = " # Using `!Send` values from a task"] #[doc = ""] #[doc = " The task supplied to `spawn` must implement `Send`. However, it is"] #[doc = " possible to **use** `!Send` values from the task as long as they only"] #[doc = " exist between calls to `.await`."] #[doc = ""] #[doc = " For example, this will work:"] #[doc = ""] #[doc = " ```"] #[doc = " use tokio::task;"] #[doc = ""] #[doc = " use std::rc::Rc;"] #[doc = ""] #[doc = " fn use_rc(rc: Rc<()>) {"] #[doc = " // Do stuff w/ rc"] #[doc = " # drop(rc);"] #[doc = " }"] #[doc = ""] #[doc = " # #[tokio::main(flavor = \"current_thread\")]"] #[doc = " # async fn main() {"] #[doc = " tokio::spawn(async {"] #[doc = " // Force the `Rc` to stay in a scope with no `.await`"] #[doc = " {"] #[doc = " let rc = Rc::new(());"] #[doc = " use_rc(rc.clone());"] #[doc = " }"] #[doc = ""] #[doc = " task::yield_now().await;"] #[doc = " }).await.unwrap();"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " This will **not**work:"] #[doc = ""] #[doc = " ```compile_fail"] #[doc = " use tokio::task;"] #[doc = ""] #[doc = " use std::rc::Rc;"] #[doc = ""] #[doc = " fn use_rc(rc: Rc<()>) {"] #[doc = " // Do stuff w/ rc"] #[doc = " # drop(rc);"] #[doc = " }"] #[doc = ""] #[doc = " #[tokio::main]"] #[doc = " async fn main() {"] #[doc = " tokio::spawn(async {"] #[doc = " let rc = Rc::new(());"] #[doc = ""] #[doc = " task::yield_now().await;"] #[doc = ""] #[doc = " use_rc(rc.clone());"] #[doc = " }).await.unwrap();"] #[doc = " }"] #[doc = " ```"] #[doc = ""] #[doc = " Holding on to a `!Send` value across calls to `.await` will result in"] #[doc = " an unfriendly compile error message similar to:"] #[doc = ""] #[doc = " ```text"] #[doc = " `[... some type ...]` cannot be sent between threads safely"] #[doc = " ```"] #[doc = ""] #[doc = " or:"] #[doc = ""] #[doc = " ```text"] #[doc = " error[E0391]: cycle detected when processing `main`"] #[doc = " ```"] #[track_caller] pub fn spawn<F>