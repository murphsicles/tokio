cfg_rt ! { #[doc = " Runs the provided closure on a thread where blocking is acceptable."] #[doc = ""] #[doc = " In general, issuing a blocking call or performing a lot of compute in a"] #[doc = " future without yielding is problematic, as it may prevent the executor from"] #[doc = " driving other futures forward. This function runs the provided closure on a"] #[doc = " thread dedicated to blocking operations. See the [CPU-bound tasks and"] #[doc = " blocking code][blocking] section for more information."] #[doc = ""] #[doc = " Tokio will spawn more blocking threads when they are requested through this"] #[doc = " function until the upper limit configured on the [`Builder`] is reached."] #[doc = " After reaching the upper limit, the tasks are put in a queue."] #[doc = " The thread limit is very large by default, because `spawn_blocking` is often"] #[doc = " used for various kinds of IO operations that cannot be performed"] #[doc = " asynchronously. When you run CPU-bound code using `spawn_blocking`, you"] #[doc = " should keep this large upper limit in mind. When running many CPU-bound"] #[doc = " computations, a semaphore or some other synchronization primitive should be"] #[doc = " used to limit the number of computations executed in parallel. Specialized"] #[doc = " CPU-bound executors, such as [rayon], may also be a good fit."] #[doc = ""] #[doc = " This function is intended for non-async operations that eventually finish on"] #[doc = " their own. If you want to spawn an ordinary thread, you should use"] #[doc = " [`thread::spawn`] instead."] #[doc = ""] #[doc = " Be aware that tasks spawned using `spawn_blocking` cannot be aborted"] #[doc = " because they are not async. If you call [`abort`] on a `spawn_blocking`"] #[doc = " task, then this *will not have any effect*, and the task will continue"] #[doc = " running normally. The exception is if the task has not started running"] #[doc = " yet; in that case, calling `abort` may prevent the task from starting."] #[doc = ""] #[doc = " When you shut down the executor, it will attempt to `abort` all tasks"] #[doc = " including `spawn_blocking` tasks. However, `spawn_blocking` tasks"] #[doc = " cannot be aborted once they start running, which means that runtime"] #[doc = " shutdown will wait indefinitely for all started `spawn_blocking` to"] #[doc = " finish running. You can use [`shutdown_timeout`] to stop waiting for"] #[doc = " them after a certain timeout. Be aware that this will still not cancel"] #[doc = " the tasks — they are simply allowed to keep running after the method"] #[doc = " returns. It is possible for a blocking task to be cancelled if it has"] #[doc = " not yet started running, but this is not guaranteed."] #[doc = ""] #[doc = " # When to use `spawn_blocking` vs dedicated threads"] #[doc = ""] #[doc = " `spawn_blocking` is intended for *bounded* blocking work that eventually finishes."] #[doc = " Each call occupies a thread from the runtime's blocking thread pool for the duration"] #[doc = " of the task. Long-lived tasks therefore reduce the pool's effective capacity, which"] #[doc = " can delay other blocking operations once the pool is saturated and work is queued."] #[doc = ""] #[doc = " For workloads that run indefinitely or for extended periods(for example,"] #[doc = " background workers or persistent processing loops), prefer a dedicated thread created with"] #[doc = " [`thread::spawn`]."] #[doc = ""] #[doc = " As a rule of thumb:"] #[doc = " - Use `spawn_blocking` for short-lived blocking operations"] #[doc = " - Use dedicated threads for long-lived or persistent blocking workloads"] #[doc = ""] #[doc = " Note that if you are using the single threaded runtime, this function will"] #[doc = " still spawn additional threads for blocking operations. The current-thread"] #[doc = " scheduler's single thread is only used for asynchronous code."] #[doc = ""] #[doc = " # Related APIs and patterns for bridging asynchronous and blocking code"] #[doc = ""] #[doc = 