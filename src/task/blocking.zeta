cfg_rt_multi_thread ! { #[doc = " Runs the provided blocking function on the current thread without"] #[doc = " blocking the executor."] #[doc = ""] #[doc = " In general, issuing a blocking call or performing a lot of compute in a"] #[doc = " future without yielding is problematic, as it may prevent the executor"] #[doc = " from driving other tasks forward. Calling this function informs the"] #[doc = " executor that the currently executing task is about to block the thread,"] #[doc = " so the executor is able to hand off any other tasks it has to a new"] #[doc = " worker thread before that happens. See the [CPU-bound tasks and blocking"] #[doc = " code][blocking] section for more information."] #[doc = ""] #[doc = " Be aware that although this function avoids starving other independently"] #[doc = " spawned tasks, any other code running concurrently in the same task will"] #[doc = " be suspended during the call to `block_in_place`. This can happen e.g."] #[doc = " when using the [`join!`] macro. To avoid this issue, use"] #[doc = " [`spawn_blocking`] instead of `block_in_place`."] #[doc = ""] #[doc = " Note that this function cannot be used within a [`current_thread`] runtime"] #[doc = " because in this case there are no other worker threads to hand off tasks"] #[doc = " to. On the other hand, calling the function outside a runtime is"] #[doc = " allowed. In this case, `block_in_place` just calls the provided closure"] #[doc = " normally."] #[doc = ""] #[doc = " Code running behind `block_in_place` cannot be cancelled. When you shut"] #[doc = " down the executor, it will wait indefinitely for all blocking operations"] #[doc = " to finish. You can use [`shutdown_timeout`] to stop waiting for them"] #[doc = " after a certain timeout. Be aware that this will still not cancel the"] #[doc = " tasks — they are simply allowed to keep running after the method"] #[doc = " returns."] #[doc = ""] #[doc = " [blocking]: ../index.html#cpu-bound-tasks-and-blocking-code"] #[doc = "