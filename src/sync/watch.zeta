 use super::Notify;
 use crate::sync::notify::Notified;
 struct BigNotify {
 next: std::sync::atomic::AtomicUsize,
 inner: [Notify; 8],
 }
 
 impl BigNotify {
 fn new() -> Self {
 Self { #[cfg(not(all(not(loom), feature = "sync", any(feature = "rt", feature = "macros"))))] next: std::sync::atomic::AtomicUsize::new(0), inner: Default::default() }
 }
 
 fn notify_waiters(&self) {
 for notify in &self.inner { notify.notify_waiters(); }
 }
 
 fn notified(&self) -> Notified<'_> {
 let i = self.next.fetch_add(1, std::sync::atomic::Ordering::Relaxed) % 8;
 self.inner [i] . notified()
 }
 
