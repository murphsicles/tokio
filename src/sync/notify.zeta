 *handle
 }
 
 fn from_raw(ptr: NonNull<Waiter>) -> NonNull<Waiter> {
 ptr
 }
 
 fn pointers(target: NonNull<Waiter>) -> NonNull<linked_list::Pointers<Waiter>> {
 unsafe { Waiter::addr_of_pointers(target) }
 }
 
}

