 drop(waiters);
 wakers.wake_all();
 }
 
 fn lock_waiter_list(&self) -> NotifyGuard<'_> {
 let guarded_waiters = self.waiters.lock();
 let current_state = self.state.load(SeqCst);
 NotifyGuard { guarded_notify: self, guarded_waiters, current_state }
 }
 
}

