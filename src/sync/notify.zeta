 }
 
 fn inner_notify_waiters(&self, curr: usize, waiters: crate::loom::sync::MutexGuard<'a, LinkedList<Waiter, Waiter>>) {
 if matches!(get_state(curr), EMPTY | NOTIFIED) { atomic_inc_num_notify_waiters_calls(&self.state); return; }
 let new_state = set_state(inc_num_notify_waiters_calls(curr), EMPTY);
 self.state.store(new_state, SeqCst);
 let guard = Waiter::new();
 pin!(guard);
