/// [`error::RecvError`]:
/// 
/// ```
/// use tokio::sync::oneshot;
/// 
/// # #[tokio::main(flavor = "current_thread")]
/// # async fn main() {
/// let(tx, rx) = oneshot::channel::<u32>();
/// 
/// tokio::spawn(async move {
/// drop(tx);
/// });
/// 
