use super::BLOCK_CAP;
const BLOCK_MASK: usize =!(BLOCK_CAP - 1);

const SLOT_MASK: usize = BLOCK_CAP - 1;

const RELEASED: usize = 1 << BLOCK_CAP;

const TX_CLOSED: usize = RELEASED << 1;

const READY_MASK: usize = RELEASED - 1;

