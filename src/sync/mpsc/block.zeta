 self.header.ready_slots.fetch_or(TX_CLOSED, Release);
 }
 
 fn reclaim(&mut self) {
 self.header.start_index = 0;
 self.header.next = AtomicPtr::new(ptr::null_mut());
 self.header.ready_slots = AtomicUsize::new(0);
