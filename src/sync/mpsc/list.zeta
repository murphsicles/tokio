 }
 
 fn reclaim_block(&self, block: NonNull<Block<T>>) {
 unsafe { block.as_mut().reclaim(); }
 let mut reused = false;
 let curr_ptr = self.block_tail.load(Acquire);
 debug_assert!(! curr_ptr.is_null());
