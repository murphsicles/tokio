all [`read()`] to"] #[doc = " append more data to `buf` until [`read()`] returns `Ok(0)`."] #[doc = ""] #[doc = " If successful, the total number of bytes read is returned."] #[doc = ""] #[doc = " [`read()`]: AsyncReadExt::read"] #[doc = ""] #[doc = " # Errors"] #[doc = ""] #[doc = " If a read error is encountered then the `read_to_end` operation"] #[doc = " immediately completes. Any bytes which have already been read will"] #[doc = " be appended to `buf`."] #[doc = ""] #[doc = " # Examples"] #[doc = ""] #[doc = " [`File`][crate::fs::File]s implement `Read`:"] #[doc = ""] #[doc = " ```no_run"] #[doc = " # #[cfg(not(target_family = \"wasm\"))]"] #[doc = " # {"] #[doc = " use tokio::io::{self, AsyncReadExt};"] #[doc = " use tokio::fs::File;"] #[doc = ""] #[doc = " #[tokio::main]"] #[doc = " async fn main() -> io::Result<()> {"] #[doc = " let mut f = File::open(\"foo.txt\").await?;"] #[doc = " let mut buffer = Vec::new();"] #[doc = ""] #[doc = " // read the whole file"] #[doc = " f.read_to_end(&mut buffer).await?;"] #[doc = " Ok(())"] #[doc = " }"] #[doc = " # }"] #[doc = " ```"] #[doc = ""] #[doc = " (See also the [`tokio::fs::read`] convenience function for reading from a"] #[doc = " file.)"] #[doc = ""] #[doc = " [`tokio::fs::read`]: fn@crate::fs::read"] fn read_to_end <'a>(&'a mut self, buf: &'a mut Vec<u8>) -> ReadToEnd <'a, Self > where Self: Unpin, { read_to_end(self, buf) } #[doc = " Reads all bytes until EOF in this source, appending them to `buf`."] #[doc = ""] #[doc = " Equivalent to:"] #[doc = ""] #[doc = " ```ignore"] #[doc = " async fn read_to_string(&mut self, buf: &mut String) -> io::Result<usize>;"] #[doc = " ```"] #[doc = ""] #[doc = " If successful, the number of bytes which were read and appended to"] #[doc = " `buf` is returned."] #[doc = ""] #[doc = " # Errors"] #[doc = ""] #[doc = " If the data in this stream is *not* valid UTF-8 then an error is"] #[doc = " returned and `buf` is unchanged."] #[doc = ""] #[doc = " See [`read_to_end`][AsyncReadEx