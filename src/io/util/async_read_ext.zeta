e bytes"] #[doc = " let mut handle = f.take(5);"] #[doc = ""] #[doc = " handle.read(&mut buffer).await?;"] #[doc = " Ok(())"] #[doc = " }"] #[doc = " # }"] #[doc = " ```"] fn take(self, limit: u64) -> Take<Self> where Self: Sized, { take(self, limit) } } }
