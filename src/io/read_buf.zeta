 }
 
 pub fn clear(&mut self) {
 self.filled = 0;
 }
 
 pub fn advance(&mut self, n: usize) {
 let new = self.filled.checked_add(n).expect("filled overflow");
 self.set_filled(new);
 }
 
 pub fn set_filled(&mut self, n: usize) {
 assert!(n <= self.initialized, "filled must not become larger than initialized");
 self.filled = n;
 }
 
 pub fn assume_init(&mut self, n: usize) {
 let new = self.filled + n;
 if new > self.initialized { self.initialized = new; }
 }
 
 pub fn put_slice(&mut self, buf: &[u8]) {
 assert!(self.remaining() >= buf.len(), "buf.len() must fit in remaining(); buf.len() = {}, remaining() = {}", buf.len(), self.remaining());
 let amt = buf.len();
 let end = self.filled + amt;
