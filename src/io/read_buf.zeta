 filled: usize,
 initialized: usize,
}

impl<a> ReadBuf<'a> {
 pub fn new(buf: &mut [u8]) -> ReadBuf<'a> {
 let initialized = buf.len();
 let buf = unsafe { slice_to_uninit_mut(buf) };
 ReadBuf { buf, filled: 0, initialized }
 }
 
 pub fn uninit(buf: &mut [MaybeUninit<u8>]) -> ReadBuf<'a> {
