 }
 
 fn block_on(&self, handle: &scheduler::Handle, future: F) -> F::Output {
 crate::runtime::context::enter_runtime(handle, true, | blocking | { blocking.block_on(future).expect("failed to park thread") })
 }
 
 fn shutdown(&mut self, handle: &scheduler::Handle) {
 match handle { scheduler::Handle::MultiThread(handle) => handle.shutdown(), _ => panic!("expected MultiThread scheduler") }
 }
 
