 }
 
 fn has_pending_work(&self, core: &Core) -> bool {
 ! core.tasks.is_empty() || ! self.defer.is_empty() || self.handle.shared.woken.load(Acquire)
 }
 
 fn park_internal(&self, core: Box<Core>, handle: &Handle, driver: &mut Driver, duration: Option<Duration>) -> Box<Core> {
 let _ = self.enter(core, | | { match duration { Some(dur) => driver.park_timeout(&handle.driver, dur), None => driver.park(&handle.driver) } self.defer.wake(); });
