 }
 
 fn enter(&self, core: Box<Core>, f: impl FnOnce) ->(Box<Core>, R) {
 *self.core.borrow_mut() = Some(core);
 let ret = f();
 let core = self.core.borrow_mut().take().expect("core missing");
