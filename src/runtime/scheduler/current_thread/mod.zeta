 }
 
 fn park(&self, core: Box<Core>, handle: &Handle) -> Box<Core> {
 let mut driver = core.driver.take().expect("driver missing");
 if let Some(f) = &handle.shared.config.before_park { let(c, ()) = self.enter(core, | | f()); core = c; }
