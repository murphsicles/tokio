}

impl Context {
 fn run_task(&self, core: Box<Core>, f: impl FnOnce) ->(Box<Core>, R) {
 core.metrics.start_poll();
 let mut ret = self.enter(core, | | crate::task::coop::budget(f));
 ret.0.metrics.end_poll();
