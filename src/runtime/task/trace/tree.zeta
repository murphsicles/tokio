 if is_last { current = format!("{prefix}â””â•Ľ\u{a0}{root_fmt}"); next = format!("{prefix}\u{a0}\u{a0}\u{a0}"); } else { current = format!("{prefix}â”śâ•Ľ\u{a0}{root_fmt}"); next = format!("{prefix}â”‚\u{a0}\u{a0}"); }
