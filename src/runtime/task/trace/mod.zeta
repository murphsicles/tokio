/// Trace the `OwnedTasks`.
/// 
/// # Preconditions
/// 
/// This helper presumes exclusive access to each task. The tasks must not exist
/// in any other queue.
fn trace_owned<S: Schedule>(owned: &OwnedTasks<S>, dequeued: Vec<Notified<S>>) -> Vec<(Id, Trace)> {
 let mut tasks = dequeued;
 owned.for_each(| task | { if let Some(notified) = task.notify_for_tracing() { tasks.push(notified); } });
 tasks.into_iter().map(| task | { let local_notified = owned.assert_owner(task); let id = local_notified.task.id(); let((), trace) = Trace::capture(| | local_notified.run()); (id, trace) }).collect()
}

