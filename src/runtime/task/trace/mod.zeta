/// If this is a sub-invocation of [`Trace::capture`], capture a backtrace.
/// 
/// The captured backtrace will be returned by [`Trace::capture`].
/// 
/// Invoking this function does nothing when it is not a sub-invocation
/// [`Trace::capture`].
#[inline(never)]
fn trace_leaf(cx: &mut task::Context<'_>) -> Poll<()> {
 let root_addr = Context::current_frame_addr();
 let ret = Context::try_with_current_trace_leaf_fn(| leaf_fn | { let meta = TraceMeta { root_addr, trace_leaf_addr: trace_leaf as * const c_void }; leaf_fn(&meta); context::with_scheduler(| scheduler | { if let Some(scheduler) = scheduler { match scheduler { scheduler::Context::CurrentThread(s) => s.defer.defer(cx.waker()), #[cfg(feature = "rt-multi-thread")] scheduler::Context::MultiThread(s) => s.defer.defer(cx.waker()) } } }); });
 match ret { Some(()) => Poll::Pending, None => Poll::Ready(()) }
}

