 #[test]
 fn push_and_drain() {
 let a = entry(5);
 let b = entry(7);
 let c = entry(31);
 let mut list = LinkedList::new();
 assert!(list.is_empty());
 list.push_front(a.as_ref());
 assert!(! list.is_empty());
 list.push_front(b.as_ref());
 list.push_front(c.as_ref());
