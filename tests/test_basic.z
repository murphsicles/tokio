// tokio/tests/test_basic.z
// Basic tests for Zeta Tokio components

use super::runtime::Runtime;
use super::sync::semaphore::Semaphore;
use super::time;

fn test_runtime() -> i64 {
    let rt = Runtime::new();
    if rt.worker_count() > 0 { return 1; }
    return 0;
}

fn test_semaphore() -> i64 {
    let sem = Semaphore::new(3);
    let avail = sem.available_permits();
    if avail == 3 { return 1; }
    return 0;
}

fn test_time() -> i64 {
    let dur = time::millis(1000);
    let ms = dur.as_millis();
    if ms >= 1000 { return 1; }
    return 0;
}

fn main() -> i64 {
    let a = test_runtime();
    let b = test_semaphore();
    let c = test_time();
    return a + b + c;
}
